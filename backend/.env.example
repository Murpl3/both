# Backend (FastAPI) environment

# REQUIRED (use a long random value in production)
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (Postgres recommended)
# Example (docker-compose):
# DATABASE_URL=postgresql+psycopg2://ezsakay:ezsakay_password@db:5432/ezsakay
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ezsakay

# CORS (comma-separated)
# For dev, you can use *
CORS_ORIGINS=*

# Admin credentials (for EZSakay Admin dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# OTP via SMS (optional). If not set, OTP will be printed in backend logs when DEBUG=true.
DEBUG=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

